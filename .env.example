# OneStopPCBA environment variables
# Copy this file to .env.local for local development and fill in real values.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend email
RESEND_API_KEY=re_your_resend_api_key
INQUIRY_NOTIFICATION_EMAIL=sales@huitaipcb.com
INQUIRY_FROM_EMAIL=noreply@huitaipcb.com

# Site URL
NEXT_PUBLIC_SITE_URL=https://huitaipcb.com

# Google Analytics 4
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Optional: set to false to disable custom GA4 conversion events.
NEXT_PUBLIC_GA_ENABLE_EVENTS=true

# Google Search Console daily report
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY=
GSC_SITE_URL=sc-domain:huitaipcb.com
